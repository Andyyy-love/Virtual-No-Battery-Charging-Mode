&i2c3 {
	aw883xx_smartpa_0: aw883xx@34 {
		compatible = "awinic,aw883xx_smartpa";
		#sound-dai-cells = <0>;
		reg = <0x34>;
		reset-gpio = <&pio 159 0x0>;
		sync-load = <1>; /*固件加载方式，若驱动以 KO 方式编译需配置为 1*/
