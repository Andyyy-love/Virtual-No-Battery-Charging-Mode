            pd,source-cap-ext = <0x8851315c 0x00000000 0x00000000
                        0x00000000 0x00000000 0x06000000 0x00000000>;
            pd,sink-cap-ext = <0x8851315c  0x00000000 0x00010000
                        0x00000000 0x05000000 0x0000000f>;
            pd,mfrs = "CPS_TCPC";

            /*
             *    VSAFE5V = 0, MAX_POWER = 1, CUSTOM = 2,
             *    MAX_POWER_LV = 0x21, MAX_POWER_LVIC = 0x31
             *    MAX_POWER_HV = 0x41, MAX_POWER_HVIC = 0x51
             */
            pd,charging_policy= <0x52>;

            /*
             * Fixed 5V, 500 mA <0x00019032>
             * Fixed 5V, 1A <0x00019064>
             * Fixed 5V, 2A <0x000190c8>
             * Fixed 5V, 3A <0x0001912c>
             * Fixed 9V, 500 mA <0x0002d032>
             * Fixed 9V, 1A <0x0002d064>
             * Fixed 9V, 2A <0x0002d0c8>
             * Fixed 9V, 3A <0x0002d12c>
             * Variable 5-9V, 1A <0x8642d064>
             * Variable 5-9V, 2A <0x8642d0c8>
             * Variable 5-9V, 3A <0x8642d12c>
             * PPS 3V~5.9V, 3A <0xC0761E3C>
             */
            pd,source-pdo-size = <1>;
            pd,source-pdo-data = <0x00019078>;
            pd,sink-pdo-size = <2>;
            pd,sink-pdo-data = <0x0001912c 0x0002d0a5>; // 9V1.65A   0x0002d0a5

            /*
             * No DP, host + device
             *    pd,id-vdo-size = <3>;
             *    pd,id-vdo-data = <0xd10029cf 0x0 0x17110000>;
             * With DP
             *    pd,id-vdo-size = <3>;
             *    pd,id-vdo-data = <0xd60029cf 0x0 0x17110000
             */

            pd,id-vdo-size = <6>;
            pd,id-vdo-data = <0xd140315c 0x0 0x88510000 0x61000000 0x0 0x41000000>;

            bat,nr = <1>;
            pd,country_nr = <0>;

            bat-info0 {
                bat,vid = <0x315c>;
                bat,pid = <0x8851>;
                bat,mfrs = "bat1";
                bat,design_cap = <5000>;
            };

            //bat-info1 {
            //    bat,vid = <0x8abc>;
            //    bat,pid = <0x5234>;
            //    bat,mfrs = "bat2";
            //    bat,design_cap = <4000>;
            //};

            //country0 {
