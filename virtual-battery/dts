		re-min = <1000>;
		re-max= <40000>;
		status = "okay";
	};
	aw883xx_smartpa_1: aw883xx@35 {
		compatible = "awinic,aw883xx_smartpa";
		#sound-dai-cells = <0>;
		reg = <0x35>;
		reset-gpio = <&pio 22 0x0>;
		sync-load = <1>; /*固件加载方式，若驱动以 KO 方式编译需配置为 1*/
		sound-channel = <1>; /*第 2 个 PA sound-channel 配置为 1*/
		re-min = <1000>;
		re-max= <40000>;
		status = "okay";
	};
